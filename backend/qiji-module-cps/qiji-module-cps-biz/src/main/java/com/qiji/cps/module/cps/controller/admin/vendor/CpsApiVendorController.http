### 请求 /cps/api-vendor/create 接口 => 成功（大淘客-淘宝）
POST {{baseUrl}}/cps/api-vendor/create
Content-Type: application/json
Authorization: Bearer {{token}}
tenant-id: {{adminTenantId}}

{
  "vendorCode": "dataoke",
  "vendorName": "大淘客",
  "vendorType": "aggregator",
  "platformCode": "taobao",
  "appKey": "DTK_TB_APP_KEY",
  "appSecret": "DTK_TB_SECRET",
  "apiBaseUrl": "https://openapi.dataoke.com/api",
  "authToken": null,
  "defaultAdzoneId": "mm_dtk_taobao_pid",
  "priority": 10,
  "status": 1
}

